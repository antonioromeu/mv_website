---
import { Image } from 'astro:assets';
import eoh_png from '../../assets/images/eoh.png';
import '../../styles/arrow.css';
import { landingContent } from '../../content/landing';

interface Props {
    lang: 'en' | 'pt';
}

const { lang } = Astro.props;
const t = landingContent[lang]; // Shortcut to the right language
---

<section 
    id="landing_page" 
    data-color="var(--color-blue)" 
    class="snap-section items-stretch
           md:flex-row md:h-screen md:items-end"
    style={`padding-top: var(--nav-height);`}
    >
    
    <!-- Text section -->
    <div class="w-full flex-1 px-[3.5vw] pb-[2vh] order-1 flex flex-col justify-center
                md:min-h-0 md:flex-1 md:pl-[1.5vw] md:pb-[3vh] md:order-2 md:justify-end
                2xl:pl-[3vw] 2xl:pr-[5vw]">
        <div class="flex flex-col mb-4
                    md:mb-6
                    2xl:mb-8">
            <span class="block text-sm
                        md:text-lg
                        xl:text-xl
                        2xl:text-2xl">
                {t.status}
            </span>
            <span class="block font-bold -mt-1 text-sm
                        md:text-lg 
                        xl:text-xl
                        2xl:text-2xl">
                {t.title}
            </span>
        </div>
        <div class="leading-relaxed
                    text-xs 
                    xl:space-y-2 xl:text-xs
                    2xl:leading-[1.75] 2xl:text-base">
            {t.description.map((para) => (
                <p set:html={para} />
            ))}
        </div>
    </div>

    <!-- Image section -->
    <div class="w-full h-auto shrink-0 order-2 flex items-end overflow-hidden
                md:w-auto md:h-full md:mt-0 md:order-1">
        <Image 
            src={eoh_png} 
            alt={t.altText} 
            width={eoh_png.width} 
            height={eoh_png.height} 
            quality="high"
            class="w-full h-auto object-contain block m-0 md:w-auto md:h-full" 
            loading="eager"
        />
    </div>

    <!-- Animated arrow -->
    <div class="absolute pb-[2vh] left-1/2 -translate-x-1/2 pointer-events-none flex justify-center items-center">
        <div class="line-container">
            <div class="line"></div>
        </div>
    </div>
</section>

<style>
    /* Scale down the arrow slightly for mobile */
    @media (max-width: 768px) {
        .line-container {
            transform: scale(0.7);
        }
    }
</style>